{
  "crons": [
    {
      "path": "/api/cron/sync-all-users",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/analyse-games",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/sync-search-console",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "app/api/cron/sync-all-users/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/analyse-games/route.ts": {
      "maxDuration": 60
    },
    "app/api/users/me/import/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/import-games/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/sync-search-console/route.ts": {
      "maxDuration": 60
    }
  }
}
