# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL via Supabase (production + local dev).
#
# DATABASE_URL  — Supabase pgBouncer pooler URL (used by the app at runtime).
#   ?pgbouncer=true        tells Prisma to skip prepared statements (required)
#   &connection_limit=1    one connection per serverless function instance
#   &statement_cache_size=0 disables statement caching — prevents "prepared
#                           statement already exists" errors with pgBouncer
#                           transaction mode
#
# DIRECT_URL — direct (non-pooled) connection, used only by `prisma migrate`.
#   Must bypass pgBouncer so migrations can use DDL transactions.
DATABASE_URL="postgresql://<user>:<password>@<pooler-host>:5432/postgres?pgbouncer=true&connection_limit=1&statement_cache_size=0"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# ── Auth (Auth.js v5 / next-auth) ────────────────────────────────────────────
# next-auth secret — generate with: openssl rand -base64 32
# Required for signing JWT session cookies.
AUTH_SECRET=""

# Canonical URL of the app (set to your custom domain in production)
AUTH_URL="http://localhost:3000"

# Auth uses username-only (public Lichess + Chess.com APIs, no OAuth tokens needed).
# Lichess and Chess.com client IDs are NOT required.

# ── Stripe (Go ad-free button) ────────────────────────────────────────────────
# Your Stripe Payment Link URL. When set, a "Go ad-free" button appears
# on the dashboard and training pages. Leave blank to hide the button.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=""

# ── Cron (game import) ────────────────────────────────────────────────────────
# Secret used to authenticate calls to /api/internal/import-games
# Generate with: openssl rand -hex 32
# Pass as header: x-cron-secret: <value>
# For Vercel Cron: set this in Vercel env vars and configure cron in vercel.json
CRON_SECRET=""

# Email — Resend (https://resend.com)
# Leave blank in dev; confirmation link will be logged to console instead.
RESEND_API_KEY=""

# Sender address for confirmation emails (must be a verified Resend domain)
EMAIL_FROM="Cassandra Chess <noreply@yourdomain.com>"

# Secret for signing email confirmation tokens — generate with: openssl rand -base64 32
SUBSCRIBE_SECRET=""

# Public base URL — used to build confirmation links
# Set to your production URL in Vercel env vars
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Creator profile page (Section 12)
# Your Chess.com username — used to pull your ratings and recent games
NEXT_PUBLIC_CREATOR_CHESSCOM_USERNAME=""

# Twitter/X handle for share button text — include the @
NEXT_PUBLIC_TWITTER_HANDLE="@cassandrachess"

NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-1008999288444187
NEXT_PUBLIC_ADSENSE_SLOT=8816444076
