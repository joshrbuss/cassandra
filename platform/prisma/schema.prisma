generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Puzzle {
  id            String   @id // Lichess puzzle ID
  /// FEN before opponent's last move (the pre-puzzle position)
  fen           String
  /// FEN after opponent's last move (the position the user sees)
  solvingFen    String
  /// Opponent's last move in UCI notation (e.g. "e2e4")
  lastMove      String
  /// Space-separated UCI solution moves (excluding the last move)
  solutionMoves String
  rating        Int
  /// Space-separated Lichess theme tags
  themes        String   @default("")
  /// "standard" | "retrograde" | "opponent_prediction" | "move_ranking" | "weakness_spot"
  type          String   @default("standard")
  /// JSON: CandidateMove[] — populated for move_ranking puzzles
  candidateMoves    String?
  /// JSON: string[] of algebraic squares, e.g. ["d5","f7"] — for weakness_spot puzzles
  weaknessSquares   String?
  /// Explanation text revealed after submitting a weakness_spot puzzle
  weaknessExplanation String?
  /// ECO opening code, e.g. "B90"
  ecoCode       String?
  /// Human-readable opening name, e.g. "Sicilian Najdorf"
  openingName   String?
  /// Lower bound of the ELO band this puzzle belongs to
  eloRangeMin   Int?
  /// Upper bound of the ELO band this puzzle belongs to
  eloRangeMax   Int?
  /// "out_of_book" | "standard" | "brilliant"
  subtype       String?
  /// "user_import" | "lichess" | "chesscom" — populated for auto-generated puzzles
  source        String?
  /// User.id of the player whose game generated this puzzle
  sourceUserId  String?
  /// false for puzzles generated from a specific user's private games
  isPublic      Boolean  @default(true)
  /// URL of the original game this puzzle was extracted from
  gameUrl          String?
  /// Opponent's username in the source game
  opponentUsername String?
  /// Date of the source game (ISO format, e.g. "2024-12-01")
  gameDate         String?
  /// "win" | "loss" | "draw" — result from the puzzle solver's perspective
  gameResult       String?
  /// Full move number when the blunder occurred (e.g. 24)
  moveNumber       Int?
  /// Centipawns at the puzzle position from the solver's perspective (positive = solver winning)
  evalCp           Int?
  /// "white" | "black" — which side the user played in the source game
  playerColor      String?
  /// True if the move deviated from opening database theory (move_ranking puzzles only)
  outOfTheory      Boolean?
  createdAt     DateTime @default(now())

  sourceUser User?           @relation(fields: [sourceUserId], references: [id], onDelete: Cascade)

  @@index([ecoCode])
  @@index([eloRangeMin, eloRangeMax])
  @@index([sourceUserId])
  @@index([source])
}

model PuzzleAttempt {
  id            String   @id @default(cuid())
  userId        String?
  puzzleId      String
  solveTimeMs   Int?
  success       Boolean
  /// 1 = first try, 2 = retry, etc. Only attemptNumber=1 counts for accuracy.
  attemptNumber Int      @default(1)
  /// First Lichess theme tag of the puzzle (e.g. "fork", "pin")
  tacticType    String?
  createdAt     DateTime @default(now())

  // No FK relation — puzzleId may reference either Puzzle or LibraryPuzzle
  @@index([puzzleId])
  @@index([userId])
  @@index([userId, tacticType])
}

model SiteStats {
  id                 Int      @id @default(1)
  totalPuzzlesSolved BigInt   @default(0)
  updatedAt          DateTime @updatedAt
}

model User {
  id                String    @id @default(cuid())
  chessComUsername  String?   @unique
  lichessUsername   String?   @unique
  chessComLinkedAt  DateTime?
  lichessLinkedAt   DateTime?
  elo               Int?
  /// Raw ELO as reported by the connected platform (shown to user)
  rawElo            Int?
  /// ELO normalized to Lichess scale for internal puzzle matching
  normalizedElo     Int?
  /// "lichess" | "chess_com" — which platform rawElo came from
  eloPlatform       String?
  avatarUrl         String?
  trialRating       Int       @default(1200) @map("battleRating")
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  /// Consecutive days without solving a puzzle
  currentLoseStreak Int       @default(0)
  /// Longest recorded lose streak
  longestLoseStreak Int       @default(0)
  /// Last date the user solved a puzzle (YYYY-MM-DD UTC)
  lastPuzzleDate    String?
  /// Last time games were synced for this user
  lastSyncedAt      DateTime?
  /// Unique 8-char referral code for sharing
  referralCode      String?   @unique
  /// Referral code of the user who referred this user
  referredBy        String?
  /// Number of referred users who have connected an account
  referralCount     Int       @default(0)
  /// True when user has earned paid status (via referrals or payment)
  isPaid            Boolean   @default(false)
  /// Email address (set when user subscribes via in-app popup)
  email             String?
  /// ISO 3166-1 alpha-2 country code (e.g. "GB", "US") — captured from Vercel IP header on signup
  country           String?
  /// Preferred UI locale (e.g. "en", "es", "fr", "de", "pt", "ru")
  locale            String?
  createdAt         DateTime  @default(now())

  puzzles            Puzzle[]
  rawGames           RawGame[]
  trialsAsPlayer1    Trial[]            @relation("TrialPlayer1")
  trialsAsPlayer2    Trial[]            @relation("TrialPlayer2")
  trialsWon          Trial[]            @relation("TrialWinner")
  userEvents         UserEvent[]
  acquisitionTouches AcquisitionTouch[]
  revenueEvents      RevenueEvent[]
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  confirmed Boolean  @default(false)
  /// "homepage" | "post_solve" | "event"
  source    String
  createdAt DateTime @default(now())
}

model Trial {
  id          String    @id @default(cuid())
  player1Id   String
  player2Id   String?
  winnerId    String?
  /// JSON: RoundResult[]
  rounds      String    @default("[]")
  /// "waiting" | "active" | "completed"
  status      String    @default("waiting")
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  player1 User  @relation("TrialPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 User? @relation("TrialPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  winner  User? @relation("TrialWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@map("Trials")
  @@index([status])
}

/// Raw game PGN queued for Stockfish analysis (chunked pipeline)
model RawGame {
  id            String   @id @default(cuid())
  userId        String
  platform      String   // "chesscom" | "lichess"
  pgn           String
  gameUrl       String?
  /// "pending" | "processing" | "done" | "failed"
  status        String   @default("pending")
  puzzlesFound  Int      @default(0)
  /// Position index to resume analysis from (chunked Stockfish processing)
  analysedUpTo  Int      @default(0)
  createdAt     DateTime @default(now())
  processedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
}

model ScalesPosition {
  id           String   @id @default(cuid())
  fen          String   @unique
  move1        String   // UCI notation, best move
  eval1        Int      // centipawns
  pv1          String?  // principal variation (space-separated UCI moves)
  move2        String   // UCI notation, 2nd best
  eval2        Int
  pv2          String?
  move3        String   // UCI notation, 3rd best
  eval3        Int
  pv3          String?
  hasSacrifice Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([id])
}

model EchoPosition {
  id           String   @id @default(cuid())
  fenBefore    String   // FEN before the move was played
  fenAfter     String   @unique // FEN after the move (shown to user)
  moveSan      String   // SAN notation, e.g. "Bxf7+"
  moveUci      String   // UCI notation, e.g. "c4f7"
  gameUrl      String?  // URL of the source game
  explanation  String   // Short description, e.g. "captures the bishop"
  createdAt    DateTime @default(now())

  @@index([id])
}

model LibraryPuzzle {
  id            String   @id @default(cuid())
  /// Lichess puzzle ID — unique identifier from Lichess database
  lichessId     String   @unique
  /// FEN before opponent's last move
  fen           String
  /// FEN after opponent's last move (position shown to solver)
  solvingFen    String
  /// Opponent's last move in UCI notation
  lastMove      String
  /// Space-separated UCI solution moves
  solutionMoves String
  rating        Int
  /// Space-separated Lichess theme tags
  themes        String   @default("")
  /// Lichess puzzle popularity score (0–100)
  popularity    Int      @default(0)
  /// URL of the original Lichess game
  gameUrl       String?
  createdAt     DateTime @default(now())

  @@index([rating])
}

/// First-party analytics events
model UserEvent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String
  event      String
  properties Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([event])
  @@index([userId, event])
}

/// UTM / channel attribution touches
model AcquisitionTouch {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String
  channel     String
  source      String?
  medium      String?
  landingPage String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([channel])
}

/// Monetisation events (Stripe webhooks, referral unlocks, etc.)
model RevenueEvent {
  id            String   @id @default(cuid())
  userId        String?
  type          String
  amount        Float
  currency      String   @default("GBP")
  stripeEventId String?  @unique
  properties    Json?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([userId, type])
}

/// Cached Google Search Console keyword performance (daily snapshots)
model SearchConsoleKeyword {
  id          String   @id @default(cuid())
  keyword     String
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  date        String   // YYYY-MM-DD
  createdAt   DateTime @default(now())

  @@unique([keyword, date])
  @@index([date])
}

/// Per-move evaluation data from v2 extraction pipeline
model MoveEval {
  id         String @id @default(cuid())
  /// Game URL or identifier linking evals to a specific game
  gameId     String
  /// Full move number (1-based)
  moveNumber Int
  /// "white" | "black" — which side made this move
  side       String
  /// Centipawn eval of the position AFTER this move was played
  evalCp     Int
  /// Centipawn eval of the best move from the position BEFORE this move
  bestMoveCp Int
  /// Centipawn loss = bestMoveCp - evalCp (0 = played the best move)
  cpl        Int
  /// "opening" | "middlegame" | "endgame"
  phase      String  @default("middlegame")
  /// UCI notation of the move played
  movePlayed String?
  /// UCI notation of the best move (engine recommendation)
  bestMove   String?
  /// Extraction version tag
  subtype    String  @default("v2")

  createdAt DateTime @default(now())

  @@index([gameId])
  @@index([gameId, side])
  @@index([subtype])
}

/// Resend email webhook events (opened, clicked, etc.)
model ResendEvent {
  id             String   @id @default(cuid())
  type           String   // "email.opened" | "email.clicked" etc.
  emailId        String
  recipientEmail String
  occurredAt     DateTime
  createdAt      DateTime @default(now())

  @@index([type])
  @@index([emailId])
}
